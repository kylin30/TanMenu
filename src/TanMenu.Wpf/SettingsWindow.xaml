<Window x:Class="TanMenu.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TanMenu 设置"
        Width="432" Height="486"
        WindowStartupLocation="Manual" ResizeMode="NoResize"
        Opacity="0"
        FontSize="13" ShowInTaskbar="True">
    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Click="Ok_Click" Width="80" Margin="0,0,8,0" Padding="0,5"/>
            <Button Content="取消" Click="Cancel_Click" Width="80" Margin="0,0,8,0" Padding="0,5"/>
            <Button x:Name="ApplyBtn" Content="应用" Click="Apply_Click" Width="80" Padding="0,5" IsEnabled="False"/>
        </StackPanel>

        <TabControl>

            <TabItem Header="外观">
                <StackPanel Margin="14">
                    <StackPanel Orientation="Horizontal" Margin="0,6" VerticalAlignment="Center">
                        <TextBlock Text="主题：" Width="90" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ThemeCombo" Width="220" SelectionChanged="Theme_Changed"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6" VerticalAlignment="Center">
                        <TextBlock Text="字体：" Width="90" VerticalAlignment="Center"/>
                        <ComboBox x:Name="FontCombo" Width="220" SelectionChanged="Font_SelectionChanged"
                                  DisplayMemberPath="Name" TextSearch.TextPath="Name" IsTextSearchEnabled="True"
                                  MaxDropDownHeight="320">
                            <ComboBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                       Foreground="#777777" Margin="2,5,2,2"/>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ComboBox.GroupStyle>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6" VerticalAlignment="Center">
                        <TextBlock Text="每列按钮数：" Width="90" VerticalAlignment="Center"/>
                        <TextBox x:Name="ColCount" Width="60" PreviewTextInput="NumberOnly" LostFocus="Col_Changed"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="行为">
                <StackPanel Margin="14">
                    <CheckBox x:Name="AutoCloseCb" Content="失焦自动隐藏" Margin="0,7" Click="Opt_Changed"/>
                    <CheckBox x:Name="TopMostCb" Content="窗口置顶" Margin="0,7" Click="Opt_Changed"/>
                    <CheckBox x:Name="TaskbarCb" Content="任务栏显示" Margin="0,7" Click="Opt_Changed"/>
                    <CheckBox x:Name="AutoStartCb" Content="开机自启" Margin="0,7" Click="AutoStart_Changed"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="文件夹">
                <StackPanel Margin="14">
                    <TextBlock Text="主文件夹" FontWeight="Bold"/>
                    <TextBlock Text="显示该文件夹下的子文件夹（例如设为桌面，桌面上的文件夹就会成为分组）。"
                               Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,4"/>
                    <DockPanel Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right" Content="选择…" Click="PickRoot_Click" Padding="14,4" Margin="8,0,0,0"/>
                        <TextBox x:Name="RootBox" IsReadOnly="True" VerticalContentAlignment="Center" Padding="4,3"/>
                    </DockPanel>

                    <TextBlock Text="数据文件夹" FontWeight="Bold"/>
                    <TextBlock Text="配置与缓存的存放位置（默认在“文档\TanMenu”）。更改会立即移动数据并生效（与“应用”按钮无关）。"
                               Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,4"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="更改…" Click="ChangeData_Click" Padding="14,4" Margin="8,0,0,0"/>
                        <TextBox x:Name="DataBox" IsReadOnly="True" VerticalContentAlignment="Center" Padding="4,3"/>
                    </DockPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="常用工具">
                <StackPanel Margin="14">
                    <CheckBox x:Name="ShowToolsCb" Content="显示“常用工具”分类" Margin="0,2,0,6" Click="ShowTools_Changed"/>
                    <TextBlock Text="勾选要在该分类中显示的工具：" Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="240">
                        <StackPanel x:Name="ToolsPanel"/>
                    </ScrollViewer>
                </StackPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
