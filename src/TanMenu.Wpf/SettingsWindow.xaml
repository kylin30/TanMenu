<Window x:Class="TanMenu.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TanMenu 设置"
        Width="520" Height="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI" FontSize="13" ShowInTaskbar="True">
    <DockPanel Margin="16">
        <Button DockPanel.Dock="Bottom" Content="关闭" Click="Close_Click"
                HorizontalAlignment="Right" Padding="18,5" Margin="0,12,0,0"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <GroupBox Header="外观" Padding="10,8" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4" VerticalAlignment="Center">
                            <TextBlock Text="主题：" Width="90" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ThemeCombo" Width="220" SelectionChanged="Theme_Changed"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4" VerticalAlignment="Center">
                            <TextBlock Text="字体：" Width="90" VerticalAlignment="Center"/>
                            <ComboBox x:Name="FontCombo" Width="220" SelectionChanged="Font_SelectionChanged"
                                      DisplayMemberPath="Name" TextSearch.TextPath="Name" IsTextSearchEnabled="True"
                                      MaxDropDownHeight="380">
                                <ComboBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                           Foreground="#777777" Margin="2,5,2,2"/>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ComboBox.GroupStyle>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4" VerticalAlignment="Center">
                            <TextBlock Text="每列按钮数：" Width="90" VerticalAlignment="Center"/>
                            <TextBox x:Name="ColCount" Width="60" PreviewTextInput="NumberOnly" LostFocus="Col_Changed"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="行为" Padding="10,8" Margin="0,0,0,12">
                    <StackPanel>
                        <CheckBox x:Name="AutoCloseCb" Content="失焦自动隐藏" Margin="0,5" Click="Opt_Changed"/>
                        <CheckBox x:Name="TopMostCb" Content="窗口置顶" Margin="0,5" Click="Opt_Changed"/>
                        <CheckBox x:Name="TaskbarCb" Content="任务栏显示" Margin="0,5" Click="Opt_Changed"/>
                        <CheckBox x:Name="AutoStartCb" Content="开机自启" Margin="0,5" Click="AutoStart_Changed"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="文件夹" Padding="10,8" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="主文件夹" FontWeight="Bold"/>
                        <TextBlock Text="显示该文件夹下的子文件夹（例如设为桌面，桌面上的文件夹就会成为分组）。"
                                   Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,4"/>
                        <DockPanel Margin="0,0,0,14">
                            <Button DockPanel.Dock="Right" Content="选择…" Click="PickRoot_Click" Padding="14,4" Margin="8,0,0,0"/>
                            <TextBox x:Name="RootBox" IsReadOnly="True" VerticalContentAlignment="Center" Padding="4,3"/>
                        </DockPanel>

                        <TextBlock Text="数据文件夹" FontWeight="Bold"/>
                        <TextBlock Text="配置与缓存的存放位置（默认在“文档\TanMenu”）。若目标文件夹已有数据则直接使用它，否则把当前数据移动过去，更改后立即生效。"
                                   Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,4"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="更改…" Click="ChangeData_Click" Padding="14,4" Margin="8,0,0,0"/>
                            <TextBox x:Name="DataBox" IsReadOnly="True" VerticalContentAlignment="Center" Padding="4,3"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
