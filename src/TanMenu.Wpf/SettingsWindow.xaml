<Window x:Class="TanMenu.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TanMenu 设置"
        Width="480" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI" FontSize="13" ShowInTaskbar="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18">

            <TextBlock Text="主文件夹" FontWeight="Bold"/>
            <TextBlock Text="显示该文件夹下的子文件夹（例如设为桌面，桌面上的文件夹就会成为分组）。"
                       Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,4"/>
            <DockPanel Margin="0,0,0,16">
                <Button DockPanel.Dock="Right" Content="选择…" Click="PickRoot_Click" Padding="14,4" Margin="8,0,0,0"/>
                <TextBox x:Name="RootBox" IsReadOnly="True" VerticalContentAlignment="Center" Padding="4,3"/>
            </DockPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,14" VerticalAlignment="Center">
                <TextBlock Text="主题：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="ThemeCombo" Width="180" SelectionChanged="Theme_Changed"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                <TextBlock Text="每列按钮数：" VerticalAlignment="Center"/>
                <TextBox x:Name="ColCount" Width="60" PreviewTextInput="NumberOnly" LostFocus="Col_Changed"/>
            </StackPanel>
            <CheckBox x:Name="AutoCloseCb" Content="失焦自动隐藏" Margin="0,4" Click="Opt_Changed"/>
            <CheckBox x:Name="TopMostCb" Content="窗口置顶" Margin="0,4" Click="Opt_Changed"/>
            <CheckBox x:Name="TaskbarCb" Content="任务栏显示" Margin="0,4" Click="Opt_Changed"/>
            <CheckBox x:Name="AutoStartCb" Content="开机自启" Margin="0,4" Click="AutoStart_Changed"/>
            <TextBlock Text="全局热键：Alt+Space（召回 / 隐藏）" Foreground="Gray" Margin="0,6,0,14"/>

            <Separator/>

            <TextBlock Text="数据文件夹" FontWeight="Bold" Margin="0,12,0,0"/>
            <TextBlock Text="配置与缓存的存放位置。若目标文件夹已有数据则直接使用它，否则把当前数据移动过去（更改后需重启生效）。"
                       Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,4"/>
            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="更改…" Click="ChangeData_Click" Padding="14,4" Margin="8,0,0,0"/>
                <TextBox x:Name="DataBox" IsReadOnly="True" VerticalContentAlignment="Center" Padding="4,3"/>
            </DockPanel>

            <Button Content="关闭" Click="Close_Click" HorizontalAlignment="Right" Padding="18,5" Margin="0,18,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>
