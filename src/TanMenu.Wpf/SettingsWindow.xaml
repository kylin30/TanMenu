<Window x:Class="TanMenu.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TanMenu 设置"
        Width="540" Height="540" MinWidth="480" MinHeight="460"
        WindowStartupLocation="Manual" ResizeMode="CanResize"
        Opacity="0"
        FontSize="13" ShowInTaskbar="True">
    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="OkBtn" Content="确定" Click="Ok_Click" Width="80" Margin="0,0,8,0" Padding="0,5"/>
            <Button x:Name="CancelBtn" Content="取消" Click="Cancel_Click" Width="80" Margin="0,0,8,0" Padding="0,5"/>
            <Button x:Name="ApplyBtn" Content="应用" Click="Apply_Click" Width="80" Padding="0,5" IsEnabled="False"/>
        </StackPanel>

        <TabControl>

            <TabItem x:Name="AppearanceTab" Header="外观">
                <StackPanel Margin="14">
                    <StackPanel Orientation="Horizontal" Margin="0,6" VerticalAlignment="Center">
                        <TextBlock x:Name="LanguageLabel" Text="语言：" Width="90" VerticalAlignment="Center"/>
                        <ComboBox x:Name="LanguageCombo" Width="220" SelectionChanged="Language_Changed"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6" VerticalAlignment="Center">
                        <TextBlock x:Name="ThemeLabel" Text="主题：" Width="90" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ThemeCombo" Width="220" SelectionChanged="Theme_Changed"/>
                        <Button x:Name="ThemeFolderBtn" Content="主题文件夹…" Margin="8,0,0,0" Padding="8,2"
                                Click="OpenThemesFolder_Click" ToolTip="打开存放自定义主题 .css 的文件夹"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6" VerticalAlignment="Center">
                        <TextBlock x:Name="FontLabel" Text="字体：" Width="90" VerticalAlignment="Center"/>
                        <ComboBox x:Name="FontCombo" Width="220" SelectionChanged="Font_SelectionChanged"
                                  DisplayMemberPath="Name" TextSearch.TextPath="Name" IsTextSearchEnabled="True"
                                  MaxDropDownHeight="320">
                            <ComboBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                       Foreground="#777777" Margin="2,5,2,2"/>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ComboBox.GroupStyle>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6" VerticalAlignment="Center">
                        <TextBlock x:Name="ColumnCountLabel" Text="每列按钮数：" Width="90" VerticalAlignment="Center"/>
                        <TextBox x:Name="ColCount" Width="60" PreviewTextInput="NumberOnly" LostFocus="Col_Changed"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6" VerticalAlignment="Center">
                        <TextBlock x:Name="ButtonSizeLabel" Text="按钮大小：" Width="90" VerticalAlignment="Center"/>
                        <ComboBox x:Name="SizeCombo" Width="220" SelectionChanged="Size_Changed"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="BehaviorTab" Header="行为">
                <StackPanel Margin="14">
                    <CheckBox x:Name="AutoCloseCb" Content="失焦自动隐藏" Margin="0,7" Click="Opt_Changed"/>
                    <CheckBox x:Name="TopMostCb" Content="窗口置顶" Margin="0,7" Click="Opt_Changed"/>
                    <CheckBox x:Name="TaskbarCb" Content="任务栏显示" Margin="0,7" Click="Opt_Changed"/>
                    <CheckBox x:Name="AutoStartCb" Content="开机自启" Margin="0,7" Click="AutoStart_Changed"/>

                    <Separator Margin="0,10"/>
                    <CheckBox x:Name="HotkeyEnabledCb" Content="启用全局热键（呼出 / 隐藏）" Margin="0,4" Click="Hotkey_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6" VerticalAlignment="Center">
                        <TextBlock x:Name="HotkeyLabel" Text="热键：" Width="50" VerticalAlignment="Center"/>
                        <TextBox x:Name="HotkeyBox" Width="190" IsReadOnly="True" VerticalContentAlignment="Center"
                                 Padding="4,3" PreviewKeyDown="Hotkey_PreviewKeyDown"
                                 ToolTip="点击后按下组合键来设置（需包含 Ctrl/Alt/Shift/Win）"/>
                        <Button x:Name="HotkeyClearBtn" Content="清除" Click="HotkeyClear_Click" Padding="12,3" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="HotkeyHelpText" Text="默认无热键。点击上方输入框并按下组合键来自定义。" Foreground="Gray"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="FoldersTab" Header="文件夹">
                <StackPanel Margin="14">
                    <TextBlock x:Name="MainFolderTitle" Text="主文件夹" FontWeight="Bold"/>
                    <TextBlock x:Name="MainFolderHelpText" Text="显示该文件夹下的子文件夹（例如设为桌面，桌面上的文件夹就会成为分组）。"
                               Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,4"/>
                    <TextBox x:Name="RootBox" IsReadOnly="True" VerticalContentAlignment="Center" Padding="4,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,18">
                        <Button x:Name="OpenRootBtn" Content="打开" Click="OpenRoot_Click" Width="76" Padding="0,4" Margin="0,0,8,0"/>
                        <Button x:Name="PickRootBtn" Content="选择…" Click="PickRoot_Click" Width="76" Padding="0,4"/>
                    </StackPanel>

                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" x:Name="DataInfoText" Foreground="Gray"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <TextBlock x:Name="DataFolderTitle" Text="数据文件夹" FontWeight="Bold"/>
                    </DockPanel>
                    <TextBlock x:Name="DataHelpText" Text="配置与缓存的存放位置（默认在“文档\TanMenu”）。更改会立即移动数据并生效（与“应用”按钮无关）。"
                               Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,4"/>
                    <TextBox x:Name="DataBox" IsReadOnly="True" VerticalContentAlignment="Center" Padding="4,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button x:Name="OpenDataBtn" Content="打开" Click="OpenData_Click" Width="76" Padding="0,4" Margin="0,0,8,0"/>
                        <Button x:Name="ChangeDataBtn" Content="更改…" Click="ChangeData_Click" Width="76" Padding="0,4" Margin="0,0,8,0"/>
                        <Button x:Name="ResetDataBtn" Content="重置为默认" Click="ResetData_Click" Padding="12,4"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="ClearCacheBtn" Content="清理缓存" Click="ClearCache_Click" Padding="12,4" Margin="0,0,8,0"/>
                        <Button x:Name="BackupBtn" Content="备份…" Click="BackupConfig_Click" Padding="12,4" Margin="0,0,8,0"/>
                        <Button x:Name="RestoreBtn" Content="恢复…" Click="RestoreConfig_Click" Padding="12,4"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="ToolsTab" Header="常用工具">
                <StackPanel Margin="14">
                    <CheckBox x:Name="ShowToolsCb" Content="显示“常用工具”分类" Margin="0,2,0,6" Click="ShowTools_Changed"/>
                    <TextBlock x:Name="ToolsHintText" Text="勾选要在该分类中显示的工具：" Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="240">
                        <StackPanel x:Name="ToolsPanel"/>
                    </ScrollViewer>
                </StackPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
