@using Microsoft.AspNetCore.Components
@*
   One window chrome for all themes. 98.css, XP.css, 7.css and fluent2.css share the same
   .window/.title-bar/.title-bar-controls/.window-body API, so only the linked
   stylesheet changes per theme. The <link>s render here (in the WebView body) so
   exactly one theme's CSS is active at a time; switching themes swaps them.
*@
@foreach (var href in Stylesheets)
{
    <link href="@href" rel="stylesheet" @key="href" />
}

<div class="@WindowClass" style="max-width: 100%">
    <div class="title-bar">
        <div class="title-bar-text"><img class="title-bar-icon" src="/app.ico" alt="" />@Title</div>
        <div class="title-bar-controls">
            <button aria-label="Minimize"></button>
            <button aria-label="Close" @onclick="@OnCloseClick"></button>
        </div>
    </div>
    <div class="window-body has-space">
        @ChildContent
    </div>
</div>

@code {
    [CascadingParameter(Name = "Theme")] public string Theme { get; set; } = "Win98";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public EventCallback OnCloseClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // fonts.css is linked AFTER 98.css so its @font-face overrides 98.css's unresolved one.
    private string[] Stylesheets => Theme switch
    {
        "Windows11" => new[] { "/lib/fluent2/fluent2.css" },
        "Win7" => new[] { "/lib/win7theme/7.css" },
        "WinXP" => new[] { "/lib/xpcss/98.css", "/lib/xpcss/fonts.css", "/lib/xpcss/xp-luna.css" },
        _ => new[] { "/lib/xpcss/98.css", "/lib/xpcss/fonts.css" },
    };

    // 7.css needs the aero "glass" class; 98/XP do not.
    private string WindowClass => Theme == "Win7" ? "window glass active" : "window active";
}
