@* SplashScreen.razor *@

@using TanMenu.Core.Services

<div class="splash-screen">
    <div class="splash-container">
        <div class="logo">
            <img src="/app.ico" alt="TanMenu" onerror="@($"this.style.display='none'; this.parentNode.innerHTML='<div style=\\'color:#0078d4;font-size:24px;font-weight:bold;\\'>TM</div>'")" />
        </div>
        <h1 class="app-name">TanMenu</h1>
        <div class="developer-info">by TanSoft</div>

        @if (ShowLoading)
        {
            <div class="loading-section">
                <div class="spinner-container">
                    <div class="spinner"></div>
                </div>
                <div class="loading-dots">
                    <span class="dot">●</span>
                    <span class="dot">●</span>
                    <span class="dot">●</span>
                </div>
            </div>
        }
        else
        {
            <div class="about-hint">@AppLanguage.Text("ClickToDismiss", Language)</div>
        }

        <div class="footer-info">
            <div class="version-info">TanMenu v@(Version)</div>
            <div class="copyright">© @DateTime.Now.Year TanSoft. All rights reserved.</div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Version { get; set; } = "1.0.0";
    [Parameter] public EventCallback OnLoadingComplete { get; set; }
    [Parameter] public bool IsVisible { get; set; } = true;
    [Parameter] public string? Language { get; set; }

    /// <summary>When false (e.g. shown as the "关于/About" overlay), hide the launch-time
    /// loading spinner/dots and show a "click to dismiss" hint instead.</summary>
    [Parameter] public bool ShowLoading { get; set; } = true;
}

<style>
    .splash-screen {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #0078d4 0%, #106ebe 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        overflow: hidden;
        z-index: 9999;
        opacity: @(IsVisible ? "1" : "0");
        transition: opacity 0.5s ease-out;
        pointer-events: @(IsVisible ? "auto" : "none");
    }

    .splash-container {
        text-align: center;
        max-width: 400px;
        padding: 20px 24px;
    }

    .logo {
        width: 60px;
        height: 60px;
        background: white;
        border-radius: 12px;
        margin: 0 auto 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
        overflow: hidden;
    }

        .logo img {
            width: 46px;
            height: 46px;
            object-fit: contain;
        }

    .app-name {
        font-size: 28px;
        font-weight: 300;
        margin-bottom: 4px;
        letter-spacing: 1px;
    }

    .developer-info {
        font-size: 14px;
        opacity: 0.85;
        margin-bottom: 16px;
        font-weight: 300;
    }

    .loading-section {
        margin-bottom: 14px;
    }

    .about-hint {
        font-size: 13px;
        opacity: 0.7;
        letter-spacing: 1px;
        margin-bottom: 14px;
    }

    .spinner-container {
        margin: 0 auto 12px;
        width: 40px;
        height: 40px;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255, 255, 255, 0.2);
        border-top: 3px solid white;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .loading-dots {
        font-size: 20px;
        opacity: 0.8;
    }

    .dot {
        animation: blink 1.4s ease-in-out infinite;
    }

        .dot:nth-child(2) {
            animation-delay: 0.2s;
        }

        .dot:nth-child(3) {
            animation-delay: 0.4s;
        }

    /* In-flow (not absolute) so it can't overlap the content — this app's window
       is content-sized, not full-screen, so the splash must fit any height. */
    .footer-info {
        margin-top: 6px;
        text-align: center;
    }

    .version-info {
        font-size: 12px;
        opacity: 0.6;
        margin-bottom: 4px;
    }

    .copyright {
        font-size: 11px;
        opacity: 0.5;
    }

    @@keyframes spin {
        from

    {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }

    }

    @@keyframes blink {
        0%, 50%

    {
        opacity: 0.3;
    }

    25% {
        opacity: 1;
    }

    }
</style>
