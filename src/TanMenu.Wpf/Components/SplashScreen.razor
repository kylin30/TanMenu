@* SplashScreen.razor *@

<div class="splash-screen">
    <div class="splash-container">
        <div class="logo">
            <img src="wwwroot/app.ico" alt="TanMenu" onerror="@($"this.style.display='none'; this.parentNode.innerHTML='<div style=\\'color:#0078d4;font-size:24px;font-weight:bold;\\'>TM</div>'")" />
        </div>
        <h1 class="app-name">TanMenu</h1>
        <div class="developer-info">by TanSoft</div>

        <div class="loading-section">
            <div class="spinner-container">
                <div class="spinner"></div>
            </div>
            <div class="loading-dots">
                <span class="dot">●</span>
                <span class="dot">●</span>
                <span class="dot">●</span>
            </div>
        </div>
    </div>

    <div class="footer-info">
        <div class="version-info">TanMenu v@Version</div>
        <div class="copyright">© @DateTime.Now.Year TanSoft. All rights reserved.</div>
    </div>
</div>

@code {
    [Parameter] public string Version { get; set; } = "1.0.0";
    [Parameter] public EventCallback OnLoadingComplete { get; set; }
    [Parameter] public bool IsVisible { get; set; } = true;
}

<style>
    .splash-screen {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #0078d4 0%, #106ebe 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        overflow: hidden;
        z-index: 9999;
        opacity: @(IsVisible ? "1" : "0");
        transition: opacity 0.5s ease-out;
        pointer-events: @(IsVisible ? "auto" : "none");
    }

    .splash-container {
        text-align: center;
        max-width: 400px;
        padding: 40px;
    }

    .logo {
        width: 80px;
        height: 80px;
        background: white;
        border-radius: 12px;
        margin: 0 auto 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

        .logo img {
            width: 60px;
            height: 60px;
            object-fit: contain;
        }

    .app-name {
        font-size: 32px;
        font-weight: 300;
        margin-bottom: 8px;
        letter-spacing: 1px;
    }

    .developer-info {
        font-size: 14px;
        opacity: 0.8;
        margin-bottom: 50px;
        font-weight: 300;
    }

    .loading-section {
        margin-bottom: 20px;
    }

    .spinner-container {
        margin: 0 auto 30px;
        width: 40px;
        height: 40px;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255, 255, 255, 0.2);
        border-top: 3px solid white;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .loading-dots {
        font-size: 20px;
        opacity: 0.8;
    }

    .dot {
        animation: blink 1.4s ease-in-out infinite;
    }

        .dot:nth-child(2) {
            animation-delay: 0.2s;
        }

        .dot:nth-child(3) {
            animation-delay: 0.4s;
        }

    .footer-info {
        position: absolute;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%);
        text-align: center;
    }

    .version-info {
        font-size: 12px;
        opacity: 0.6;
        margin-bottom: 5px;
    }

    .copyright {
        font-size: 11px;
        opacity: 0.5;
    }

    @@keyframes spin {
        from

    {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }

    }

    @@keyframes blink {
        0%, 50%

    {
        opacity: 0.3;
    }

    25% {
        opacity: 1;
    }

    }
</style>