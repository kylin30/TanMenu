@using TanMenu.Wpf.Services
@using TanMenu.Wpf.ViewModels
@using TanMenu.Wpf.Components.Retro
@using TanMenu.Core.Services
@using TanMenu.Core.Models
@implements IDisposable
@inject MenuService MenuService
@inject ConfigService ConfigService
@inject IWindowHost WindowHost
@inject ILaunchService LaunchService
@inject ISettingsLauncher SettingsLauncher
@inject IShellCommands ShellCommands
@inject AppEvents Events
@inject Microsoft.Extensions.Logging.ILogger<Index> Logger

<div class="body theme-@ThemeClass">
    @if (!string.IsNullOrEmpty(SafeFont))
    {
        <style>
            /* Cover every element in the window — the launcher buttons' text lives in
               .button-body, which declares its own font-family, so a parent-only override
               wouldn't reach it. */
            .body .window,
            .body .window * {
                font-family: "@SafeFont", sans-serif !important;
            }
        </style>
    }
    <CascadingValue Value="@_theme" Name="Theme">
        <RetroWindow Title="TanMenu" OnCloseClick="@HandleClose">
            <div id="form-content">
                <div class="tm-menubar" role="menubar">
                    <span class="tm-menuitem" role="menuitem" @onclick="OpenRoot"><u>打</u>开主目录</span>
                    <span class="tm-menuitem" role="menuitem" @onclick="OpenSettings"><u>选</u>项</span>
                    <span class="tm-menuitem" role="menuitem" @onclick="Refresh"><u>刷</u>新</span>
                    <span class="tm-menuitem" role="menuitem" @onclick="ExitApp"><u>退</u>出</span>
                </div>
                @if (_groups.Count > 0)
                {
                    <div class="flex items-start gap-2">
                        @foreach (var grp in _groups)
                        {
                            <RetroGroupbox Title="@grp.DirectoryName"
                                OnTitleClickAction="@(() => LaunchService.OpenFolder(grp.Directory))">
                                <div class="flex items-start gap-1">
                                    @foreach (var col in grp.Items.Chunk(_cfg.General.ColButtonCount))
                                    {
                                        <div>
                                            @foreach (var item in col)
                                            {
                                                <div class="mb-1 flex-shrink-0">
                                                    <RetroButton Text="@item.Name"
                                                        IconBase64="@item.IconBase64"
                                                        Disabled="@item.IsDisabled"
                                                        OnClick="@(() => AppRun(item))" />
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </RetroGroupbox>
                        }
                    </div>
                }
                else
                {
                    <SplashScreen/>
                }
            </div>
        </RetroWindow>
    </CascadingValue>
</div>

@code {
    private List<MenuGroupVm> _groups = new();
    private AppConfig _cfg = new();
    private string _theme = "Win98";

    /// <summary>Sanitized font family — safe to inline into the &lt;style&gt; block (the stored
    /// value is user free-text, so strip any CSS-breaking characters before rendering).</summary>
    private string SafeFont => FontUtil.Sanitize(_cfg.General.FontFamily);

    protected override async Task OnInitializedAsync()
    {
        Events.SettingsChanged += OnSettingsChanged;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _cfg = ConfigService.Config;
        _theme = ResolveTheme(_cfg.General.ThemeName);
        _groups = await MenuService.GetMenuFromRootAsync(_cfg.RootFolder);
        Logger.LogInformation("Index loaded {Count} groups from root '{Root}', theme {Theme}",
            _groups.Count, _cfg.RootFolder, _theme);
    }

    // Map the stored theme name to a supported key; anything unknown (e.g. the removed
    // "Win31"/"ModernRetro") falls back to the default Win98.
    private static string ResolveTheme(string? name) => name switch
    {
        "WinXP" => "WinXP",
        "Win7" => "Win7",
        _ => "Win98",
    };

    private string ThemeClass => _theme switch
    {
        "WinXP" => "winxp",
        "Win7" => "win7",
        _ => "win98",
    };

    private void OnSettingsChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await ReloadAsync();
            StateHasChanged();
            await Task.Delay(60);
            await WindowHost.ResizeToContentAndPlaceAsync();
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            await WindowHost.ResizeToContentAndPlaceAsync();
        }
    }

    private void AppRun(MenuItemVm item)
    {
        LaunchService.Launch(item.FullPath);
        WindowHost.Hide();
    }

    private void HandleClose() => WindowHost.Hide();

    private void OpenSettings() => SettingsLauncher.Open();

    private void OpenRoot()
    {
        if (!string.IsNullOrWhiteSpace(_cfg.RootFolder))
            LaunchService.OpenFolder(_cfg.RootFolder);
    }

    private async Task Refresh()
    {
        await ReloadAsync();
        StateHasChanged();
        await Task.Delay(60);
        await WindowHost.ResizeToContentAndPlaceAsync();
    }

    private void ExitApp() => ShellCommands.Exit();

    public void Dispose() => Events.SettingsChanged -= OnSettingsChanged;
}
