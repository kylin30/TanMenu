@using System.Diagnostics
@using TanMenu.Core.Services
@inject SoundService SoundService

<button class="modern-retro-button @(Disabled ? "disabled" : "")"
        disabled="@Disabled"
        @onclick="OnClickHandler"
        @onmouseenter="OnMouseEnter"
        style="width: 100%;">
    @if (!string.IsNullOrEmpty(IconBase64))
    {
        <span class="button-icon">
            <img src="data:image/png;base64,@IconBase64" alt="" />
        </span>
    }
    @if (!string.IsNullOrEmpty(Text))
    {
        <span class="button-text">@Text</span>
    }
    @ChildContent
</button>

@code {
    [Parameter] public string? Text { get; set; }
    [Parameter] public string? IconBase64 { get; set; }
    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool EnableSounds { get; set; } = true;

    private async Task OnClickHandler()
    {
        if (!Disabled && OnClick.HasDelegate)
        {
            // 播放点击声音（火忘模式，不等待）
            if (EnableSounds)
            {
                _ = SoundService.PlayClickSoundAsync();
            }

            await OnClick.InvokeAsync();
        }
    }

    private void OnMouseEnter()
    {
        Debug.WriteLine("Button hovered: " + Text);
        if (!Disabled && EnableSounds)
        {
            // 播放悬停声音（火忘模式，不等待）
            _ = SoundService.PlayHoverSoundAsync();
        }
    }
}

<style>
    .modern-retro-button {
        background-color: #f0f0f0;
        border: 2px solid #333;
        color: #333;
        padding: 8px 16px;
        font-size: 16px;
        border-radius: 6px;
        box-shadow:
            inset -3px -3px 0 #ccc,
            3px 3px 0 #333;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: flex-start;
        gap: 6px;
        min-height: 36px;
        width: 100%;
        margin: 0;
        box-sizing: border-box;
        text-align: left;
        position: relative;
        font-weight: bold;
        letter-spacing: 1px;
    }

    .modern-retro-button:hover:not(.disabled) {
        background-color: #007acc;
        border: 2px solid #005599;
        color: #ffffff;
        box-shadow: 
            inset 2px 2px 0 #004488,
            inset -2px -2px 0 #0099ff;
    }

    .modern-retro-button:active:not(.disabled) {
        box-shadow:
            inset -2px -2px 0 #ccc,
            2px 2px 0 #333;
    }

    .modern-retro-button.disabled {
        background-color: #d0d0d0;
        border: 2px solid #999;
        color: #999;
        cursor: not-allowed;
        opacity: 0.6;
        box-shadow:
            inset -2px -2px 0 #aaa,
            2px 2px 0 #999;
    }

    .button-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        width: 20px;
        height: 20px;
    }

    .button-icon img {
        width: 20px;
        height: 20px;
        display: block;
        image-rendering: pixelated;
        image-rendering: -moz-crisp-edges;
        image-rendering: crisp-edges;
    }

    .modern-retro-button.disabled .button-icon img {
        opacity: 0.5;
        filter: grayscale(100%);
    }

    .button-text {
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        flex: 1;
        text-align: left;
        text-transform: uppercase;
        font-weight: inherit;
    }

    .modern-retro-button:focus:not(.disabled) {
        outline: 2px solid #007acc;
        outline-offset: 2px;
    }
</style>