@* Renders the retro launcher button of the active theme. *@
@if (Theme == "Win7")
{
    <TanMenu.Wpf.Components.Windows7.Button Text="@Text" IconBase64="@IconBase64" Disabled="@Disabled" OnClick="@OnClick" />
}
else if (Theme == "ModernRetro")
{
    <TanMenu.Wpf.Components.ModernRetro.Button Text="@Text" IconBase64="@IconBase64" Disabled="@Disabled" OnClick="@OnClick" />
}
else
{
    <TanMenu.Wpf.Components.Windows3_1.Button Text="@Text" IconBase64="@IconBase64" Disabled="@Disabled" OnClick="@OnClick" />
}

@code {
    [CascadingParameter(Name = "Theme")] public string Theme { get; set; } = "Win31";
    [Parameter] public string? Text { get; set; }
    [Parameter] public string? IconBase64 { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
}
